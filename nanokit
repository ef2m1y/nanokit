# Symlink items from an ECC subdirectory into the corresponding ~/.claude/ subdirectory.
# Usage: _ecc_link_component <repo_subdir> <claude_subdir> <names_array[@]> [ext]
#   repo_subdir  — directory under $ECC_DIR  (e.g. "skills", "agents", "commands")
#   claude_subdir — directory under ~/.claude (e.g. "skills", "agents", "commands")
#   names_array  — bash array of item names
#   ext          — optional file extension for flat files (e.g. ".md"); omit for directories
_ecc_link_component() {
    local repo_sub="$1" claude_sub="$2" ext="${4:-}"
    shift 2
    local -n _names="$1"
    shift
    ext="${1:-}"

    local src_dir="$ECC_DIR/$repo_sub"
    local dst_dir="$ECC_CLAUDE_DIR/$claude_sub"
    mkdir -p "$dst_dir"

    # Clean up stale non-symlink items left by the old plugin install
    local cleaned=0
    local name
    for name in "${_names[@]}"; do
        local target="$dst_dir/${name}${ext}"
        if [[ -e "$target" && ! -L "$target" ]]; then
            rm -rf "$target"
            cleaned=$((cleaned + 1))
        fi
    done
    if [[ $cleaned -gt 0 ]]; then
        print_info "Cleaned $cleaned old $repo_sub item(s)"
    fi

    local count=0 skipped=0
    for name in "${_names[@]}"; do
        local src="$src_dir/${name}${ext}"
        local dst="$dst_dir/${name}${ext}"

        if [[ ! -e "$src" ]]; then
            print_warning "$repo_sub '$name' not found in ECC repo (skipped)"
            skipped=$((skipped + 1))
            continue
        fi

        if [[ -e "$dst" && ! -L "$dst" ]]; then
            print_warning "Skipping $repo_sub '$name' (existing non-symlink)"
            skipped=$((skipped + 1))
            continue
        fi
        ln -sfn "$src" "$dst"
        count=$((count + 1))
    done
    print_success "Linked $count ECC $repo_sub"
    if [[ $skipped -gt 0 ]]; then
        print_warning "$skipped $repo_sub skipped"
    fi
}

# Remove all symlinks under a directory that point into $ECC_DIR.
_ecc_remove_links() {
    local dir="$1"
    [[ -d "$dir" ]] || return 0
    local removed=0
    for link in "$dir"/*; do
        [[ -L "$link" ]] || continue
        local resolved
        resolved="$(readlink "$link")"
        if [[ "$resolved" == "$ECC_DIR"/* ]]; then
            rm "$link"
            removed=$((removed + 1))
        fi
    done
    if [[ $removed -gt 0 ]]; then
        print_success "Removed $removed symlink(s) from $dir"
    fi
}

ecc_install() {
    print_ascii_art

    print_step "Installing ECC (Everything Claude Code)..."
    echo ""

    if ! command -v git &> /dev/null; then
        print_error "git is required. Install with: pixi global install git"
        exit 1
    fi

    if [[ -d "$ECC_DIR/.git" ]]; then
        print_step "Updating existing ECC clone..."
        git -C "$ECC_DIR" pull --ff-only
    else
        print_step "Cloning ECC repository to $ECC_DIR..."
        mkdir -p "$(dirname "$ECC_DIR")"
        git clone --depth 1 "$ECC_REPO" "$ECC_DIR"
    fi
    print_success "ECC repository ready"
    echo ""

    _ecc_link_component "skills"   "skills"   ECC_SELECTED_SKILLS
    _ecc_link_component "agents"   "agents"   ECC_SELECTED_AGENTS   ".md"
    _ecc_link_component "commands" "commands" ECC_SELECTED_COMMANDS ".md"
    echo ""

    print_info "ECC docs: https://github.com/affaan-m/everything-claude-code"
    print_success "🔧 ECC installed. Restart Claude Code to load changes."
}

ecc_update() {
    if [[ ! -d "$ECC_DIR/.git" ]]; then
        print_error "ECC is not installed. Run: ./nanokit ecc-install"
        exit 1
    fi
    ecc_install
}

ecc_uninstall() {
    print_ascii_art

    print_warning "This will remove ECC symlinks and the clone at $ECC_DIR"
    read -p "🗑️  Proceed? (y/N): " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Cancelled"
        return 0
    fi

    _ecc_remove_links "$ECC_CLAUDE_DIR/skills"
    _ecc_remove_links "$ECC_CLAUDE_DIR/agents"
    _ecc_remove_links "$ECC_CLAUDE_DIR/commands"

    if [[ -d "$ECC_DIR" ]]; then
        print_step "Removing ECC clone..."
        rm -rf "$ECC_DIR"
        print_success "Removed $ECC_DIR"
    fi

    print_success "🧹 ECC uninstalled"
}

# Codex CLI (OpenAI) optional setup — installed via npm to get the latest upstream release,
# since conda-forge tends to lag. Uses the nodejs env managed by pixi-global.toml.
CODEX_NPM_PACKAGE="@openai/codex"

# Expose a binary installed into the pixi nodejs env by symlinking it into ~/.pixi/bin,
# which pixi already puts on PATH. Keeps npm-installed CLIs discoverable without editing
# pixi-global.toml's [envs.nodejs] exposed table (which would be overwritten by `pixi global sync`).
codex_link_binary() {
    local npm_prefix bin_src bin_dst
    npm_prefix="$(npm prefix -g 2>/dev/null)"
    if [[ -z "$npm_prefix" ]]; then
        print_warning "Could not determine npm global prefix."
        return 1
    fi
    bin_src="$npm_prefix/bin/codex"
    bin_dst="$HOME/.pixi/bin/codex"

    if [[ ! -x "$bin_src" ]]; then
        print_warning "codex binary not found at $bin_src"
        return 1
    fi

    mkdir -p "$HOME/.pixi/bin"
    ln -sfn "$bin_src" "$bin_dst"
    print_success "Linked $bin_dst -> $bin_src"
}

codex_install() {
    print_ascii_art

    print_step "Installing OpenAI Codex CLI ($CODEX_NPM_PACKAGE)..."
    echo ""

    if ! command -v npm &> /dev/null; then
        print_error "npm is required. Install with: pixi global install nodejs"
        exit 1
    fi

    npm install -g "$CODEX_NPM_PACKAGE"
    print_success "Codex CLI installed"
    echo ""

    codex_link_binary
    echo ""

    if command -v codex &> /dev/null; then
        print_info "Version: $(codex --version 2>/dev/null || echo 'unknown')"
    else
        print_warning "codex command not found on PATH. Ensure ~/.pixi/bin is on PATH."
    fi
    echo ""

    # Register Codex as an MCP server in Claude Code (skipped if claude CLI absent)
    codex_mcp_register
    echo ""

    print_info "Next steps (interactive, run manually):"
    print_info "  1. codex login        # authenticate Codex"
    print_info "  2. codex setup        # select default model"
    print_info "  3. Restart Claude Code to load the new MCP server"
    print_success "🧠 Codex CLI setup completed!"
}

codex_update() {
    if ! command -v npm &> /dev/null; then
        print_error "npm is required. Install with: pixi global install nodejs"
        exit 1
    fi

    print_step "Updating Codex CLI to latest..."
    npm install -g "$CODEX_NPM_PACKAGE@latest"
    print_success "Codex CLI updated"
    codex_link_binary
    if command -v codex &> /dev/null; then
        print_info "Version: $(codex --version 2>/dev/null || echo 'unknown')"
    fi
}

codex_uninstall() {
    print_ascii_art

    print_warning "This will remove Codex CLI ($CODEX_NPM_PACKAGE) from npm global."
    read -p "🗑️  Proceed? (y/N): " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Cancelled"
        return 0
    fi

    if ! command -v npm &> /dev/null; then
        print_error "npm is not available; nothing to uninstall via npm."
        exit 1
    fi

    print_step "Removing Codex CLI..."
    npm uninstall -g "$CODEX_NPM_PACKAGE" || true

    local bin_dst="$HOME/.pixi/bin/codex"
    if [[ -L "$bin_dst" ]]; then
        rm -f "$bin_dst"
        print_success "Removed $bin_dst"
    fi

    print_success "🧹 Codex CLI uninstalled"
}

# Main function
main() {
    case "${1:-}" in
        "install")
            install
            ;;
        "claude-setup")
            claude_setup
            ;;
        "aris-install")
            aris_install
            ;;
        "aris-update")
            aris_update
            ;;
        "aris-uninstall")
            aris_uninstall
            ;;
        "last30days-install")
            last30days_install
            ;;
        "last30days-update")
            last30days_update
            ;;
        "last30days-uninstall")
            last30days_uninstall
            ;;
        "ecc-install")
            ecc_install
            ;;
        "ecc-update")
            ecc_update
            ;;
        "ecc-uninstall")
            ecc_uninstall
            ;;
        "codex-install")
            codex_install
            ;;
        "codex-update")
            codex_update
            ;;
        "codex-uninstall")
            codex_uninstall
            ;;
        "uninstall")
            uninstall
            ;;
        "--help"|"-h"|"help")
