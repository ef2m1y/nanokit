#!/bin/bash

# 🛠️ nanokit - minimal development environment
# Command-line tool for managing nanokit setup

set -e  # Exit on any error

# Resolve nanokit repo root (directory of this script)
NANOKIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Print colored output
print_step() {
    echo -e "${BLUE}🔧 $1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_info() {
    echo -e "${CYAN}ℹ️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Print ASCII art
print_ascii_art() {
    echo -e "${PURPLE}"
    cat << 'EOF'

                                                   88         88
                                                   88         ""    ,d
                                                   88               88
8b,dPPYba,   ,adPPYYba,  8b,dPPYba,    ,adPPYba,   88   ,d8   88  MM88MMM
88P'   `"8a  ""     `Y8  88P'   `"8a  a8"     "8a  88 ,a8"    88    88
88       88  ,adPPPPP88  88       88  8b       d8  8888[      88    88
88       88  88,    ,88  88       88  "8a,   ,a8"  88`"Yba,   88    88,
88       88  `"8bbdP"Y8  88       88   `"YbbdP"'   88   `Y8a  88    "Y888

nanokit - minimal development environment

EOF
    echo -e "${NC}"
}

# Show help
show_help() {
    print_ascii_art
    
    echo -e "${CYAN}Usage:${NC}"
    echo "  nanokit <command>"
    echo ""
    echo -e "${CYAN}Commands:${NC}"
    echo "  install         🚀 Install and setup nanokit environment"
    echo "  claude-setup    🤖 Setup Claude Code configuration and plugins"
    echo "  aris-install    🌙 Install ARIS research skills into ~/.claude/skills (optional)"
    echo "  aris-update     🔄 Update ARIS skills to the latest version"
    echo "  aris-uninstall  🧹 Remove ARIS skills and clone"
    echo "  uninstall       🗑️ Uninstall nanokit and remove all configurations"
    echo "  --help          📖 Show this help message"
    echo ""
    echo -e "${CYAN}Examples:${NC}"
    echo "  nanokit install"
    echo "  nanokit uninstall"
    echo ""
}

# Install nanokit
install() {
    print_ascii_art
    
    print_step "Starting nanokit installation..."
    echo ""
    
    # Install dotter
    print_step "Installing dotter..."
    pixi global install dotter-rs
    print_success "dotter installed"
    echo ""
    
    # Backup existing pixi-global.toml if it exists
    local pixi_global_file="$HOME/.pixi/manifests/pixi-global.toml"
    if [[ -f "$pixi_global_file" ]]; then
        print_step "Backing up existing pixi-global.toml..."
        mv "$pixi_global_file" "$pixi_global_file.bak"
        print_success "Backup created: $pixi_global_file.bak"
        echo ""
    fi
    
    # Deploy dotfiles
    print_step "Deploying dotfiles..."
    dotter deploy
    print_success "Dotfiles deployed"
    echo ""
    
    # Sync global packages
    print_step "Syncing global packages..."
    pixi global sync
    print_success "Global packages synced"
    echo ""
    
    # Install Claude Code
    print_step "Installing Claude Code..."
    curl -fsSL https://claude.ai/install.sh | bash
    print_success "Claude Code installed"
    echo ""

    # Setup Claude Code configuration and plugins
    claude_setup

    print_success "🎉 Setup completed successfully!"
    echo ""

    # Ask to launch zsh
    read -p "🚀 Launch zsh now? (Y/n): " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        print_success "Launching zsh..."
        exec zsh
    else
        print_info "You can launch zsh manually with: zsh"
    fi
}

# Uninstall nanokit
uninstall() {
    print_ascii_art
    
    print_warning "Confirm you exited (pixi-installed) zsh! Execute ./nanokit uninstall in bash."
    echo ""
    
    read -p "🐚 Are you running this in bash (not pixi zsh)? (Y/n): " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Nn]$ ]]; then
        print_info "Please exit zsh and run './nanokit uninstall' in bash"
        exit 0
    fi
    
    echo ""
    print_warning "Uninstall nanokit?"
    echo ""
    
    read -p "🗑️  Are you sure you want to proceed? (y/N): " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        print_step "Uninstalling nanokit..."
        
        # Remove symlinks
        dotter undeploy -d
        dotter undeploy
        
        # Create empty pixi-global.toml
        print_step "Removing nanokit global tools..."
        touch ~/.pixi/manifests/pixi-global.toml
        pixi global sync

        echo ""
        print_success "Nanokit uninstalled successfully!"
    else
        print_info "Uninstall cancelled"
    fi
}

# Setup Claude Code configuration and plugins
claude_setup() {
    print_ascii_art

    print_step "Setting up Claude Code configuration..."
    echo ""

    # Check if claude CLI is available
    if ! command -v claude &> /dev/null; then
        print_warning "Claude Code is not installed."
        print_info "Install with: npm install -g @anthropic-ai/claude-code"
        print_info "Then re-run: nanokit claude-setup"
        exit 1
    fi

    # Deploy config symlinks via dotter
    print_step "Deploying Claude Code config symlinks..."
    dotter deploy
    print_success "Config symlinks deployed"
    echo ""

    # Register plugin marketplaces
    print_step "Registering plugin marketplaces..."
    claude plugin marketplace add affaan-m/everything-claude-code 2>/dev/null || true
    claude plugin marketplace add Lum1104/Understand-Anything 2>/dev/null || true
    claude plugin marketplace add DenDen047/claude-scientific-skills 2>/dev/null || true
    print_success "Marketplaces registered"
    echo ""

    # Install plugins
    print_step "Installing Claude Code plugins..."
    claude plugin install everything-claude-code@everything-claude-code 2>/dev/null || true
    claude plugin install understand-anything@understand-anything 2>/dev/null || true
    claude plugin install scientific-skills@claude-scientific-skills 2>/dev/null || true
    print_success "Plugins installed"
    echo ""

    # Setup Scrapling MCP server
    print_step "Setting up Scrapling MCP server..."
    local scrapling_dir="$NANOKIT_ROOT/claude/mcp-servers/scrapling"
    if [[ -f "$scrapling_dir/pixi.toml" ]]; then
        pixi install --manifest-path "$scrapling_dir/pixi.toml" 2>/dev/null && \
            print_success "Scrapling pixi environment installed" || \
            print_warning "Scrapling pixi install failed"
        pixi run --manifest-path "$scrapling_dir/pixi.toml" install-browsers 2>/dev/null && \
            print_success "Scrapling browser dependencies installed" || \
            print_warning "Scrapling browser install failed (non-critical, basic scraping still works)"
        claude mcp add -s user scrapling -- pixi run --manifest-path "$scrapling_dir/pixi.toml" mcp 2>/dev/null && \
            print_success "Scrapling MCP server registered" || \
            print_warning "Scrapling MCP registration failed"
    else
        print_warning "Scrapling pixi.toml not found at $scrapling_dir"
    fi
    echo ""

    # Show next steps
    print_info "Next steps:"
    print_info "  1. Configure local settings: ~/.claude/settings.local.json"
    echo ""
    print_success "🤖 Claude Code setup completed!"
}

# ARIS (Auto-Research-In-Sleep) optional setup
ARIS_REPO="https://github.com/wanshuiyin/Auto-claude-code-research-in-sleep.git"
ARIS_DIR="$NANOKIT_ROOT/claude/external/aris"
ARIS_SKILLS_DIR="$HOME/.claude/skills"

aris_install() {
    print_ascii_art

    print_step "Installing ARIS (Auto-Research-In-Sleep) skills..."
    echo ""

    if ! command -v git &> /dev/null; then
        print_error "git is required. Install with: pixi global install git"
        exit 1
    fi

    if [[ -d "$ARIS_DIR/.git" ]]; then
        print_step "Updating existing ARIS clone..."
        git -C "$ARIS_DIR" pull --ff-only
    else
        print_step "Cloning ARIS repository to $ARIS_DIR..."
        mkdir -p "$(dirname "$ARIS_DIR")"
        git clone --depth 1 "$ARIS_REPO" "$ARIS_DIR"
    fi
    print_success "ARIS repository ready"
    echo ""

    if [[ ! -d "$ARIS_DIR/skills" ]]; then
        print_error "ARIS skills directory not found at $ARIS_DIR/skills"
        exit 1
    fi

    mkdir -p "$ARIS_SKILLS_DIR"

    print_step "Symlinking ARIS skills into $ARIS_SKILLS_DIR..."
    local count=0
    local skipped=0
    for skill_path in "$ARIS_DIR"/skills/*/; do
        [[ -d "$skill_path" ]] || continue
        local name
        name="$(basename "$skill_path")"
        local target="$ARIS_SKILLS_DIR/$name"

        if [[ -e "$target" && ! -L "$target" ]]; then
            print_warning "Skipping '$name' (existing non-symlink)"
            skipped=$((skipped + 1))
            continue
        fi
        ln -sfn "${skill_path%/}" "$target"
        count=$((count + 1))
    done
    print_success "Linked $count ARIS skill(s)"
    if [[ $skipped -gt 0 ]]; then
        print_warning "$skipped skill(s) skipped due to name collision"
    fi
    echo ""

    print_info "ARIS docs: https://github.com/wanshuiyin/Auto-claude-code-research-in-sleep"
    print_success "🌙 ARIS installed. Restart Claude Code to load new skills."
}

aris_update() {
    if [[ ! -d "$ARIS_DIR/.git" ]]; then
        print_error "ARIS is not installed. Run: ./nanokit aris-install"
        exit 1
    fi
    aris_install
}

aris_uninstall() {
    print_ascii_art

    print_warning "This will remove ARIS symlinks and the clone at $ARIS_DIR"
    read -p "🗑️  Proceed? (y/N): " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Cancelled"
        return 0
    fi

    if [[ -d "$ARIS_SKILLS_DIR" ]]; then
        print_step "Removing ARIS symlinks from $ARIS_SKILLS_DIR..."
        local removed=0
        for link in "$ARIS_SKILLS_DIR"/*; do
            [[ -L "$link" ]] || continue
            local resolved
            resolved="$(readlink "$link")"
            if [[ "$resolved" == "$ARIS_DIR"/* ]]; then
                rm "$link"
                removed=$((removed + 1))
            fi
        done
        print_success "Removed $removed ARIS symlink(s)"
    fi

    if [[ -d "$ARIS_DIR" ]]; then
        print_step "Removing ARIS clone..."
        rm -rf "$ARIS_DIR"
        print_success "Removed $ARIS_DIR"
    fi

    print_success "🧹 ARIS uninstalled"
}

# Main function
main() {
    case "${1:-}" in
        "install")
            install
            ;;
        "claude-setup")
            claude_setup
            ;;
        "aris-install")
            aris_install
            ;;
        "aris-update")
            aris_update
            ;;
        "aris-uninstall")
            aris_uninstall
            ;;
        "uninstall")
            uninstall
            ;;
        "--help"|"-h"|"help")
            show_help
            ;;
        "")
            show_help
            ;;
        *)
            print_error "Unknown command: $1"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"
